{
  "name": "record-store-locator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon",
    "db:migrate": "knex migrate:latest",
    "db:seed": "knex seed:run",
    "db:reset": "knex migrate:rollback --all && npm run db:setup",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "dev:setup": "npm run db:setup && npm run dev"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "debug": "~4.4.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-errors": "^2.0.0",
    "knex": "^3.2.6",
    "morgan": "~1.10.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
